modules = ["web", "bash", "nodejs-22"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 2785
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "vm"
run = ["node", "dist/main"]
build = ["npm", "run", "build:all"]

[userenv]

[userenv.development]
PUPPETEER_EXECUTABLE_PATH = "/nix/store/qa9cnw4v5xkxyip6mb9kxqfq1z4x2dx1-chromium-138.0.7204.100/bin/chromium"

[userenv.shared]
NODE_ENV = "production"
PORT = "2785"
DATABASE_TYPE = "sqlite"
DATABASE_PORT = "5432"
DATABASE_USERNAME = "postgres"
DATABASE_NAME = "postgres"
DATABASE_SYNCHRONIZE = "true"
MAIN_DATABASE_SYNCHRONIZE = "true"
REDIS_ENABLED = "false"
REDIS_PORT = "6379"
ENGINE_TYPE = "whatsapp-web.js"
SESSION_DATA_PATH = "./data/sessions"
PUPPETEER_HEADLESS = "true"
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD = "true"
PUPPETEER_ARGS = "--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage,--disable-gpu"
STORAGE_TYPE = "local"
STORAGE_LOCAL_PATH = "./data/media"
WEBHOOK_TIMEOUT = "10000"
WEBHOOK_MAX_RETRIES = "3"
WEBHOOK_RETRY_DELAY = "5000"
RATE_LIMIT_TTL = "60"
RATE_LIMIT_MAX = "100"
PLUGINS_ENABLED = "true"
PLUGINS_DIR = "./data/plugins"
LOG_LEVEL = "info"
CORS_ORIGINS = "https://openwa.teamora.site"
AUTO_START_SESSIONS = "false"
XDG_CONFIG_HOME = "/tmp/.config"
XDG_CACHE_HOME = "/tmp/.cache"
